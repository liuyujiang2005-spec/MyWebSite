# 后端：Node 22（内置 node:sqlite），tsx 运行 TypeScript
FROM node:22-alpine

WORKDIR /app

RUN npm install -g tsx@4.19.2

COPY packages/shared-types ./packages/shared-types
COPY apps/api ./apps/api

ENV NODE_ENV=production
ENV PORT=3001
# 持久化 SQLite 时挂载卷并设置路径，例如：/data/app.sqlite
ENV SQLITE_PATH=/data/app.sqlite

RUN mkdir -p /data

EXPOSE 3001

CMD ["tsx", "apps/api/src/main.ts"]
